{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://the-invention-club.local/schemas/curriculum.v1.json",
  "title": "Invention Club Curriculum Source",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "meta",
    "levels",
    "skill_cards",
    "power_cards",
    "integration_cards",
    "invention_cards",
    "asset_inventory",
    "preload_profiles",
    "lesson_plan_profiles",
    "red_team_cases",
    "audit_warnings"
  ],
  "properties": {
    "meta": {
      "type": "object",
      "additionalProperties": true,
      "required": ["schema_version", "source_status", "generation_timestamp_policy", "baseline_note"],
      "properties": {
        "schema_version": { "const": "curriculum.v1" },
        "source_status": { "type": "string", "minLength": 1 },
        "generation_timestamp_policy": { "type": "string", "minLength": 1 },
        "baseline_note": { "type": "string", "minLength": 1 }
      }
    },
    "levels": {
      "type": "array",
      "minItems": 6,
      "maxItems": 6,
      "items": { "$ref": "#/$defs/level" }
    },
    "skill_cards": {
      "type": "array",
      "minItems": 10,
      "items": { "$ref": "#/$defs/skill_card" }
    },
    "power_cards": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/power_card" }
    },
    "integration_cards": {
      "type": "array",
      "items": { "$ref": "#/$defs/integration_card" }
    },
    "invention_cards": {
      "type": "array",
      "items": { "$ref": "#/$defs/invention_card" }
    },
    "asset_inventory": { "$ref": "#/$defs/asset_inventory" },
    "preload_profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/preload_profile" }
    },
    "lesson_plan_profiles": {
      "type": "array",
      "items": { "$ref": "#/$defs/lesson_plan_profile" }
    },
    "red_team_cases": {
      "type": "array",
      "items": { "type": "object", "required": ["case", "classification", "families_involved"] }
    },
    "audit_warnings": {
      "type": "array",
      "items": { "type": "object", "required": ["id", "source", "summary"] }
    }
  },
  "$defs": {
    "level": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "name", "child_facing_summary", "facilitator_definition", "coding_expectation", "dimensions"],
      "properties": {
        "id": { "type": "integer", "minimum": 1, "maximum": 6 },
        "name": { "type": "string", "minLength": 1 },
        "child_facing_summary": { "type": "string", "minLength": 1 },
        "facilitator_definition": { "type": "string", "minLength": 1 },
        "coding_expectation": { "type": "string", "minLength": 1 },
        "dimensions": { "$ref": "#/$defs/level_dimensions" }
      }
    },
    "level_dimensions": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "adult_support",
        "child_independence",
        "kit_state",
        "coding_expectation",
        "physical_build_complexity",
        "debugging_evidence_expectation",
        "integration_readiness"
      ],
      "properties": {
        "adult_support": { "type": "string", "minLength": 1 },
        "child_independence": { "type": "string", "minLength": 1 },
        "kit_state": { "type": "string", "minLength": 1 },
        "coding_expectation": { "type": "string", "minLength": 1 },
        "physical_build_complexity": { "type": "string", "minLength": 1 },
        "debugging_evidence_expectation": { "type": "string", "minLength": 1 },
        "integration_readiness": { "type": "string", "minLength": 1 }
      }
    },
    "skill_card": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "name",
        "label",
        "group",
        "suit",
        "primary_learning_problem",
        "levels",
        "icon_asset"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "group": { "type": "string", "minLength": 1 },
        "suit": { "type": "string", "minLength": 1 },
        "primary_learning_problem": { "type": "string", "minLength": 1 },
        "levels": {
          "type": "array",
          "minItems": 6,
          "items": {
            "type": "object",
            "required": ["level", "name", "focus"],
            "properties": {
              "level": { "type": "integer", "minimum": 1, "maximum": 6 },
              "name": { "type": "string", "minLength": 1 },
              "focus": { "type": "string", "minLength": 1 }
            }
          }
        },
        "icon_asset": { "type": "string", "minLength": 1 },
        "summary": { "type": "string" }
      }
    },
    "power_card": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "i_can_statement",
        "primary_family",
        "level",
        "dependencies",
        "materials",
        "success_condition",
        "debug_prompts",
        "stretch_challenge",
        "possible_integrations",
        "supporting_families",
        "classification_rationale",
        "result_image",
        "result_alt"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "i_can_statement": { "type": "string", "minLength": 1 },
        "primary_family": { "type": "string", "minLength": 1 },
        "level": { "type": "integer", "minimum": 1, "maximum": 6 },
        "dependencies": { "type": "array", "items": { "type": "string" } },
        "materials": { "type": "array", "items": { "type": "string" } },
        "success_condition": { "type": "string", "minLength": 1 },
        "debug_prompts": { "type": "array", "items": { "type": "string" } },
        "stretch_challenge": { "type": "string", "minLength": 1 },
        "possible_integrations": { "type": "array", "items": { "type": "string" } },
        "supporting_families": { "type": "array", "items": { "type": "string" } },
        "classification_rationale": { "type": "string" },
        "result_image": { "type": "string", "minLength": 1 },
        "result_alt": { "type": "string", "minLength": 1 },
        "required_assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/required_asset" }
        }
      }
    },
    "integration_card": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "title",
        "families_combined",
        "required_power_cards",
        "challenge",
        "success_condition",
        "choice_points",
        "make_it_yours_prompts"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "title": { "type": "string", "minLength": 1 },
        "families_combined": { "type": "array", "items": { "type": "string" } },
        "required_power_cards": { "type": "array", "items": { "type": "string" } },
        "challenge": { "type": "string", "minLength": 1 },
        "success_condition": { "type": "string", "minLength": 1 },
        "choice_points": { "type": "array", "items": { "type": "string" } },
        "make_it_yours_prompts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "invention_card": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "theme",
        "open_ended_challenge",
        "possible_skill_families",
        "constraints",
        "reflection_prompts"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "theme": { "type": "string", "minLength": 1 },
        "open_ended_challenge": { "type": "string", "minLength": 1 },
        "possible_skill_families": { "type": "array", "items": { "type": "string" } },
        "constraints": { "type": "array", "items": { "type": "string" } },
        "reflection_prompts": { "type": "array", "items": { "type": "string" } }
      }
    },
    "asset_inventory": {
      "type": "object",
      "additionalProperties": true,
      "required": ["version", "assets", "scene_assignments", "scene_runtime", "future_svg_generation"],
      "properties": {
        "version": { "type": "integer" },
        "assets": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["id", "category", "path"],
            "properties": {
              "id": { "type": "string", "minLength": 1 },
              "category": { "type": "string", "minLength": 1 },
              "path": { "type": "string", "minLength": 1 }
            }
          }
        },
        "physical_assets": {
          "type": "array",
          "items": { "$ref": "#/$defs/physical_asset" }
        },
        "programmable_preload_profiles": {
          "type": "array",
          "items": { "$ref": "#/$defs/programmable_preload_profile" }
        },
        "scene_assignments": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["card_id", "family", "template", "accent"],
            "properties": {
              "card_id": { "type": "string", "minLength": 1 },
              "family": { "type": "string", "minLength": 1 },
              "template": { "type": "string", "minLength": 1 },
              "accent": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "storage_location": {
      "type": "object",
      "additionalProperties": false,
      "required": ["zone", "bin_id", "bin_label", "compartment", "return_location", "pack_order"],
      "properties": {
        "zone": { "type": "string", "minLength": 1 },
        "bin_id": { "type": "string", "minLength": 1 },
        "bin_label": { "type": "string", "minLength": 1 },
        "compartment": { "type": "string", "minLength": 1 },
        "return_location": { "type": "string", "minLength": 1 },
        "pack_order": { "type": "integer", "minimum": 1 }
      }
    },
    "safety_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": ["hazards", "supervision_level", "age_floor", "inspection_check", "return_check"],
      "properties": {
        "hazards": { "type": "array", "items": { "type": "string" } },
        "supervision_level": {
          "enum": ["standard", "direct", "adult_controlled", "demo_only"]
        },
        "age_floor": { "type": "integer", "minimum": 0 },
        "inspection_check": { "type": "string", "minLength": 1 },
        "return_check": { "type": "string", "minLength": 1 },
        "electrical_limits": { "type": "object", "additionalProperties": true }
      }
    },
    "stock_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": ["reusable", "consumable", "reorder_unit", "reorder_trigger"],
      "properties": {
        "reusable": { "type": "boolean" },
        "consumable": { "type": "boolean" },
        "reorder_unit": { "type": "string", "minLength": 1 },
        "reorder_trigger": { "type": "string", "minLength": 1 }
      }
    },
    "programming_state": {
      "enum": ["blank", "preloaded_locked", "child_editable_template", "child_authored_allowed"]
    },
    "physical_asset": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "kit_code", "label", "category", "storage", "default_preparation_state"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kit_code": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "short_label": { "type": "string", "minLength": 1 },
        "category": { "type": "string", "minLength": 1 },
        "storage": { "$ref": "#/$defs/storage_location" },
        "default_preparation_state": {
          "enum": ["blank", "preloaded", "loose", "prebuilt", "adult-prepared"]
        },
        "safety": { "$ref": "#/$defs/safety_profile" },
        "stock": { "$ref": "#/$defs/stock_profile" },
        "session_notes": { "type": "string" }
      }
    },
    "programmable_preload_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "id",
        "label",
        "board_asset_id",
        "description",
        "adult_preparation_notes",
        "programming_state",
        "board_delivery_state",
        "child_editable",
        "blank_board_compatible"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "label": { "type": "string", "minLength": 1 },
        "board_asset_id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "adult_preparation_notes": { "type": "string", "minLength": 1 },
        "programming_state": { "$ref": "#/$defs/programming_state" },
        "board_delivery_state": { "type": "string", "minLength": 1 },
        "child_editable": { "type": "boolean" },
        "blank_board_compatible": { "type": "boolean" }
      }
    },
    "required_asset": {
      "type": "object",
      "additionalProperties": true,
      "required": ["asset_id", "quantity", "quantity_basis", "preparation_state", "preparation_notes"],
      "properties": {
        "asset_id": { "type": "string", "minLength": 1 },
        "quantity": { "type": "integer", "minimum": 1 },
        "quantity_basis": {
          "enum": ["per_child", "per_pair", "per_table", "per_session", "demo_only"]
        },
        "preparation_state": {
          "enum": ["blank", "preloaded", "loose", "prebuilt", "adult-prepared"]
        },
        "preparation_notes": { "type": "string", "minLength": 1 },
        "preload_profile_id": { "type": "string", "minLength": 1 },
        "programming_state": { "$ref": "#/$defs/programming_state" }
      }
    },
    "preload_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "description", "asset_ids"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "description": { "type": "string", "minLength": 1 },
        "asset_ids": { "type": "array", "items": { "type": "string" } }
      }
    },
    "lesson_plan_profile": {
      "type": "object",
      "additionalProperties": true,
      "required": ["id", "name", "output_dir", "source_card_type", "include"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "name": { "type": "string", "minLength": 1 },
        "output_dir": { "type": "string", "minLength": 1 },
        "source_card_type": { "type": "string", "minLength": 1 },
        "include": { "type": "array", "items": { "type": "string" } }
      }
    }
  }
}
